{
  "uid": "qoocca-basic",
  "title": "Qoocca API - Basic",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP RPS",
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"qoocca-db\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 (s)",
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"qoocca-db\"}[1m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx Rate",
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",application=\"qoocca-db\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used (bytes)",
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\",application=\"qoocca-db\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU Usage",
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"qoocca-db\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hikari Active Connections",
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"qoocca-db\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hikari Pending Connections",
      "id": 12,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "hikaricp_connections_pending{application=\"qoocca-db\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MySQL Threads Connected",
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MySQL Slow Queries (rate)",
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_slow_queries[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MySQL Questions (rate)",
      "id": 9,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_questions[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MySQL Buffer Pool Reads (rate)",
      "id": 10,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_innodb_buffer_pool_reads[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 by URI (s)",
      "id": 11,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"qoocca-db\"}[1m])) by (le, uri))",
          "refId": "A"
        }
      ]
    }
  ]
}
